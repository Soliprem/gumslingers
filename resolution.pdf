/CMapType 0 def
/WMode 0 def
1 begincodespacerange
<0000> <FFFF>
endcodespacerange
1 beginbfchar
<0001> <0020>
endbfchar
endcmap
CMapName currentdict /CMap defineresource pop
end
end
%%EndResource
